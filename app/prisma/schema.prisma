generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Area {
  id          String      @id
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  employees   employees[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model User {
  id            String     @id
  email         String     @unique
  password      String
  name          String?
  emailVerified DateTime?
  image         String?
  role          UserRole   @default(EMPLOYEE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  Account       Account[]
  Session       Session[]
  employees     employees?
  bonosUploads  bonos_uploads[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model attachments {
  id             String         @id
  leaveRequestId String
  fileName       String
  originalName   String
  filePath       String
  fileType       String
  fileSize       Int
  createdAt      DateTime       @default(now())
  leave_requests leave_requests @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model employee_documents {
  id           String    @id @db.VarChar(255)
  employeeId   String    @db.VarChar(255)
  fileName     String    @db.VarChar(500)
  originalName String    @db.VarChar(500)
  filePath     String    @db.VarChar(1000)
  fileType     String    @db.VarChar(100)
  fileSize     Int
  documentType String    @db.VarChar(100)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  employees    employees @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([documentType])
  @@index([employeeId])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model employees {
  id                  String               @id
  userId              String               @unique
  dni                 String               @unique
  firstName           String
  lastName            String
  birthDate           DateTime
  hireDate            DateTime
  areaId              String
  position            String
  phone               String?
  photo               String?
  vacationDays        Int                  @default(20)
  personalHours       Int                  @default(96)
  remoteHours         Int                  @default(96)
  availableHours      Int                  @default(16)
  totalVacationDays   Int                  @default(20)
  totalPersonalHours  Int                  @default(96)
  totalRemoteHours    Int                  @default(96)
  totalAvailableHours Int                  @default(16)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  employee_documents  employee_documents[]
  Area                Area                 @relation(fields: [areaId], references: [id])
  User                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leave_requests      leave_requests[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model leave_requests {
  id          String           @id
  employeeId  String
  type        LeaveRequestType
  startDate   DateTime
  endDate     DateTime
  isHalfDay   Boolean          @default(false)
  hours       Int?
  startTime   String?
  endTime     String?
  shift       DayShift?
  reason      String
  status      RequestStatus    @default(PENDING)
  adminNotes  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime
  attachments attachments[]
  employees   employees        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

enum DayShift {
  MORNING
  AFTERNOON
  FULL_DAY
}

enum LeaveRequestType {
  License
  Vacation
  Personal
  Remote
  Hours
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum BonosArchivoTipo {
  HORARIOS
  TICKETS_HORAS
  FERIADOS
}

model bonos_uploads {
  id           String            @id
  mesAnio      String            @db.Char(7)
  tipoArchivo  BonosArchivoTipo
  fileName     String            @db.VarChar(500)
  fileHash     String?           @db.VarChar(64)
  recordsCount Int               @default(0)
  loadedBy     String
  loadedAt     DateTime          @default(now())
  updatedAt    DateTime
  horarios     bonos_horarios[]
  tickets      bonos_tickets_horas[]
  feriados     bonos_feriados[]
  User         User              @relation(fields: [loadedBy], references: [id], onDelete: Restrict)

  @@unique([mesAnio, tipoArchivo])
  @@index([mesAnio])
  @@index([tipoArchivo])
}

model bonos_horarios {
  id              String        @id
  uploadId        String
  mesAnio         String        @db.Char(7)
  nombreRelojRaw  String        @db.VarChar(255)
  nombreRelojNorm String        @db.VarChar(255)
  fecha           DateTime      @db.Date
  turno           DayShift
  horaEntrada     String?       @db.VarChar(5)
  horaSalida      String?       @db.VarChar(5)
  rowNumber       Int
  createdAt       DateTime      @default(now())
  bonos_uploads   bonos_uploads @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([mesAnio])
  @@index([nombreRelojNorm])
  @@index([fecha])
}

model bonos_tickets_horas {
  id                    String        @id
  uploadId              String
  mesAnio               String        @db.Char(7)
  nroTicket             String?       @db.VarChar(100)
  semana                String?       @db.VarChar(50)
  responsableRaw        String        @db.VarChar(255)
  responsableNormApe    String        @db.VarChar(255)
  asunto                String?       @db.VarChar(500)
  tipo                  String?       @db.VarChar(100)
  horasExtras           Float
  rowNumber             Int
  createdAt             DateTime      @default(now())
  bonos_uploads         bonos_uploads @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([mesAnio])
  @@index([responsableNormApe])
  @@index([semana])
}

model bonos_feriados {
  id            String        @id
  uploadId      String
  mesAnio       String        @db.Char(7)
  fecha         DateTime      @db.Date
  conmemoracion String?       @db.VarChar(255)
  rowNumber     Int
  createdAt     DateTime      @default(now())
  bonos_uploads bonos_uploads @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([mesAnio])
  @@index([fecha])
}
